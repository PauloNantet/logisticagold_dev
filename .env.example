# ============================================
# Fatura App 3.7 - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores
# No Railway, configure estas variáveis no painel do serviço

# Porta do servidor (Railway define automaticamente)
PORT=3001

# Chave secreta para JWT (MUDE EM PRODUÇÃO!)
JWT_SECRET=substitua-por-uma-chave-segura-e-longa-aqui

# URL de conexão com PostgreSQL (use para ambiente local)
DATABASE_URL=postgresql://postgres:[SENHA]@db.[PROJETO].supabase.co:5432/postgres

# URL privada do Railway (usada automaticamente em produção)
# NÃO configure manualmente - o Railway define automaticamente
# DATABASE_PRIVATE_URL=

# Ambiente (defina como "production" no Railway)
NODE_ENV=production
